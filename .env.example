# ─── 嗓音训练云端服务配置 ─────────────────────────────
# 以下配置用于接入 vfs-tracker 的 AWS 后端服务。
# 必须部署相应的 AWS 基础设施才能使用相关功能。
# 参考: docs/CLOUD_DEPLOYMENT.md

# AWS 区域
AWS_REGION=us-east-1

# Cognito 用户池
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# API Gateway 端点
API_ENDPOINT=

# S3 存储桶
S3_BUCKET=

# ─── AI 鼓励消息 (OpenAI 兼容) ──────────────────────
# 这些也可以在应用内的 "API 配置" 页面设置
AI_API_ENDPOINT=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
